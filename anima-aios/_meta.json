{
  "ownerId": "kn7aebmvtwr0yh7eevaxy6g4qx81t5zk",
  "slug": "anima-aios",
  "version": "6.2.2",
  "publishedAt": 1774209600000,
  "homepage": "https://github.com/anima-aios/anima",
  "security": "SECURITY.md",
  "requirements": {
    "python": ["watchdog>=3.0.0"]
  },
  "environment": {
    "ANIMA_FACTS_BASE": {
      "description": "Facts 数据存储基础路径",
      "default": "/home/画像",
      "required": false
    },
    "ANIMA_WORKSPACE": {
      "description": "OpenClaw workspace 路径（可选，用于 agent 名称解析）",
      "default": "自动检测",
      "required": false
    },
    "ANIMA_AGENT_NAME": {
      "description": "Agent 中文名（可选，用于覆盖自动检测）",
      "default": "自动检测",
      "required": false
    }
  },
  "config": {
    "team_mode": {
      "description": "是否启用团队排行（扫描其他 Agent 数据）",
      "default": false,
      "type": "boolean"
    },
    "auto_import": {
      "description": "安装后是否自动导入 OpenClaw 原生记忆",
      "default": false,
      "type": "boolean"
    }
  }
}